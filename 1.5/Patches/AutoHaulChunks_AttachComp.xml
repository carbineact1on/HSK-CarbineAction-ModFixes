<?xml version="1.0" encoding="utf-8" ?>
<!--
    Mod-Fixes: attach CompAutoHaulChunks to drill/extractor buildings so
    chunks they drop are auto-flagged for hauling (Quarry-style).

    The comp is universal — anyone can attach it to any building via XML
    in their own patch mod. Mod-Fixes ships it pre-attached to the most
    common HSK + vanilla drill/extractor defs:
      - DeepDrill           (vanilla)
      - Extractor           (HSK Core_SK mine extractor)
      - RareExtractor       (HSK Core_SK advanced mine extractor)

    Optional Alpha Biomes core sample drill: covered via PatchOperationFindMod
    guard at the bottom (no-op if AB isn't loaded).
-->
<Patch>

    <Operation Class="PatchOperationAdd">
        <success>Always</success>
        <xpath>Defs/ThingDef[defName="DeepDrill"]/comps</xpath>
        <value>
            <li Class="ModFixesPack.AutoHaulChunks.CompProperties_AutoHaulChunks" />
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <success>Always</success>
        <xpath>Defs/ThingDef[defName="Extractor"]/comps</xpath>
        <value>
            <li Class="ModFixesPack.AutoHaulChunks.CompProperties_AutoHaulChunks" />
        </value>
    </Operation>

    <Operation Class="PatchOperationAdd">
        <success>Always</success>
        <xpath>Defs/ThingDef[defName="RareExtractor"]/comps</xpath>
        <value>
            <li Class="ModFixesPack.AutoHaulChunks.CompProperties_AutoHaulChunks" />
        </value>
    </Operation>

    <!-- Alpha Biomes core sample drill — only if Alpha Biomes is loaded.
         Wrapped in PatchOperationFindMod so it's a no-op when AB isn't
         present. Update the defName if AB uses a different one. -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Alpha Biomes</li>
        </mods>
        <match Class="PatchOperationAdd">
            <success>Always</success>
            <xpath>Defs/ThingDef[defName="AB_CoreSampleDrill"]/comps</xpath>
            <value>
                <li Class="ModFixesPack.AutoHaulChunks.CompProperties_AutoHaulChunks" />
            </value>
        </match>
    </Operation>

</Patch>
