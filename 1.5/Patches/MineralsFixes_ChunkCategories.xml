<?xml version="1.0" encoding="utf-8" ?>
<!--
    Mod-Fixes: restore vanilla StoneChunks category on Minerals mod chunks.

    Problem: Minerals mod (zacharyfoster.minerals) defines 3 chunk subcategories
    (SoftStoneChunks, HardStoneChunks, UltraHardStoneChunks) and uses
    <thingCategories Inherit="False"> on its abstract bases. That REPLACES the
    inherited vanilla StoneChunks category with the subcategory only.

    Result:
      - Minerals chunks (Claystone, Mudstone, Basalt, etc.) don't show up in
        vanilla "Stone Chunks" storage filters
      - Recipes / jobs that look for StoneChunks don't see them
      - Mod-Fixes auto-haul works (it walks the parent chain to Chunks),
        but having StoneChunks directly is more robust

    Fix: add vanilla StoneChunks alongside each Minerals subcategory so
    the chunks are tagged with both. Still organized by hardness in Minerals'
    own UI subcategories, but also visible in vanilla filters.

    Guarded by PatchOperationFindMod so it's a no-op when Minerals isn't loaded.
-->
<Patch>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Minerals</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[@Name="ZF_SoftStoneChunksBase"]/thingCategories</xpath>
                    <value>
                        <thingCategories>
                            <li>StoneChunks</li>
                            <li>SoftStoneChunks</li>
                        </thingCategories>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[@Name="ZF_HardStoneChunksBase"]/thingCategories</xpath>
                    <value>
                        <thingCategories>
                            <li>StoneChunks</li>
                            <li>HardStoneChunks</li>
                        </thingCategories>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[@Name="ZF_UltraHardStoneChunksBase"]/thingCategories</xpath>
                    <value>
                        <thingCategories>
                            <li>StoneChunks</li>
                            <li>UltraHardStoneChunks</li>
                        </thingCategories>
                    </value>
                </li>

                <!-- ZF_BlocksClay's def has <thingCategories IsNull="true"/>
                     which the user reported leaves clay blocks without a
                     storage category ("no place to store: clay blocks").

                     Conditional: only replace thingCategories if StoneBlocks
                     isn't already present. Some mods (or HSK's own load order)
                     may have already restored the category — adding it again
                     would log "duplicate thingCategory StoneBlocks" config
                     errors at boot. -->
                <li Class="PatchOperationConditional">
                    <xpath>Defs/ThingDef[defName="ZF_BlocksClay"]/thingCategories/li[text()="StoneBlocks"]</xpath>
                    <nomatch Class="PatchOperationReplace">
                        <xpath>Defs/ThingDef[defName="ZF_BlocksClay"]/thingCategories</xpath>
                        <value>
                            <thingCategories>
                                <li>StoneBlocks</li>
                            </thingCategories>
                        </value>
                    </nomatch>
                </li>

            </operations>
        </match>
    </Operation>

</Patch>
